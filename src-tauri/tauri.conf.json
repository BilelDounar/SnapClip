{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapClip",
  "version": "0.1.0",
  "identifier": "com.snapclip.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SnapClip",
        "url": "index.html",
        "width": 380,
        "height": 580,
        "minWidth": 340,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
